# Скрипты предназначены для исполнения на Linux — принудительно LF,
# независимо от core.autocrlf на машине контрибьютора (иначе CRLF в shebang
# ломает запуск на сервере: "bad interpreter").
*.sh text eol=lf
*.conf text eol=lf
*.cron text eol=lf
*.logrotate text eol=lf
*.example text eol=lf
*.xml text eol=lf
